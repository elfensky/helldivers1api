{
    "name": "helldivers1api",
    "version": "0.1.2",
    "description": "This stores historical data from the Helldivers 1 API and functions as a rebroadcaster and cache to prevent the stats page and bot from over-querying the API.",
    "homepage": "https://github.com/elfensky/helldivers1api#readme",
    "bugs": {
        "url": "https://github.com/elfensky/helldivers1api/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/elfensky/helldivers1api.git"
    },
    "author": "Andrei Lavrenov",
    "license": "UNLICENSED",
    "main": "index.js",
    "type": "module",
    "keywords": [
        "rebroadcast",
        "historic",
        "express",
        "cache",
        "data",
        "api"
    ],
    "scripts": {
        "dev": "npx nodemon",
        "start": "node ./src/index.js",
        "test": "vitest",
        "test:watch": "vitest --watch"
    },
    "volta": {
        "node": "22.14.0",
        "npm": "11.3.0"
    },
    "dependencies": {
        "@sentry/node": "^9.12.0",
        "fastify": "^5.3.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.9",
        "vitest": "^3.1.1"
    }
}
